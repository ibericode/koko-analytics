#!/usr/bin/env php
<?php

// Usage: bin/db-seed [years]
// Needs access to wp-config.php at the default WordPress location.

class Command
{
    protected function table_exists(string $table): bool
    {
        global $wpdb;

        return $wpdb->get_var($wpdb->prepare('SHOW TABLES LIKE %s', $table)) === $table;
    }

    public function create_referrer_urls(int $n_referrers): array
    {
        global $wpdb;

        $table = $wpdb->prefix . 'koko_analytics_referrer_labels';
        // $wpdb->query("TRUNCATE {$wpdb->prefix}koko_analytics_referrer_labels");
        $count = (int) $wpdb->get_var("SELECT COUNT(*) FROM $table");
        $n = $n_referrers - $count;
       
        echo "# Generating referrers\n";
        for ($i = 0; $i < $n; $i++) {
            $url = "referrer-$i.com";
            $wpdb->insert(
                $table,
                array(
                    'value' => $url,
                )
            );
            echo "\r" . round($i / $n * 100) . "% completed";
        }
        echo "\rDone. Generated {$n} unique referrers.\n";

        return array_map(function ($row) {
            return (int) $row->id;
        }, $wpdb->get_results("SELECT id FROM $table"));
    }

    public function create_utm_values(): array
    {
        global $wpdb;

        $values_by_type = array(
            'utm_source' => array('google', 'newsletter', 'facebook', 'linkedin', 'wordpress.org', 'github', 'partner-site'),
            'utm_medium' => array('organic', 'email', 'social', 'referral', 'cpc'),
            'utm_campaign' => array('spring-sale', 'product-launch', 'black-friday', 'docs-refresh', 'plugin-page'),
        );
        $ids_by_type = array();

        foreach ($values_by_type as $type => $values) {
            $table = $wpdb->prefix . 'koko_analytics_' . $type . '_labels';
            if (!$this->table_exists($table)) {
                continue;
            }

            echo "# Generating {$type} labels\n";
            foreach ($values as $value) {
                $wpdb->query($wpdb->prepare("INSERT IGNORE INTO $table(value) VALUES(%s)", $value));
            }

            $ids_by_type[$type] = array_map(function ($row) {
                return (int) $row->id;
            }, $wpdb->get_results("SELECT id FROM $table"));
        }

        return $ids_by_type;
    }


    public function create_paths(int $n): array
    {
        global $wpdb;

        $table = $wpdb->prefix . 'koko_analytics_paths';
        // $wpdb->query("TRUNCATE {$wpdb->prefix}koko_analytics_paths");
        $count = (int) $wpdb->get_var("SELECT COUNT(*) FROM $table");
        $n = $n - $count;

        echo "# Generating paths\n";
        for ($i = 0; $i < $n; $i++) {
            $random_string = bin2hex(random_bytes(4));
            $wpdb->insert(
                $table,
                array(
                    'path' => "/path-{$random_string}/",
                )
            );
            echo "\r" . round($i / $n * 100) . "% completed";
        }
        echo "\rDone. Generated {$n} unique paths.\n";

        return array_map(function ($row) {
            return (int) $row->id;
        }, $wpdb->get_results("SELECT id FROM $table"));
    }


    public function __invoke(array $arguments = [])
    {
        global $wpdb;

        $years = (int) ($arguments[1] ?? 5);
        $n_paths = $years * 100; // 500 paths by default
        $n_referrers =  $years * 200; // 1000 referrers by default;

        // empty current data
        $wpdb->query("TRUNCATE {$wpdb->prefix}koko_analytics_site_stats");
        $wpdb->query("TRUNCATE {$wpdb->prefix}koko_analytics_post_stats");
        $wpdb->query("TRUNCATE {$wpdb->prefix}koko_analytics_referrer_stats");
        foreach (array('utm_source', 'utm_medium', 'utm_campaign') as $type) {
            $table = $wpdb->prefix . 'koko_analytics_' . $type . '_stats';
            if ($this->table_exists($table)) {
                $wpdb->query("TRUNCATE $table");
            }
        }

        $paths = $this->create_paths($n_paths);
        $referrers = $this->create_referrer_urls($n_referrers);
        $utm_values = $this->create_utm_values();

        echo "# Generating stats\n";
        for ($dt = new \DateTimeImmutable('now'), $i = 0; $dt > new \DateTimeImmutable("-{$years} years"); $dt = $dt->modify('-1 day'), $i++) {
            $date = $dt->format('Y-m-d');
            $pageviews = rand(10, 1000);
            $visitors = (int) (rand(2, 6) * $pageviews * 0.1);

            // simulate a huge peak in traffic every 180 days (this helps test chart scaling)
            if (rand(1, 180) === 1) {
                $pageviews = $pageviews * 10;
                $visitors  = $visitors * 10;
            }

            $wpdb->query($wpdb->prepare("INSERT INTO {$wpdb->prefix}koko_analytics_site_stats(date, pageviews, visitors) VALUES(%s, %d, %d)", array($date, $pageviews, $visitors)));
            
            $this->seed_post_stats($paths, $date, $pageviews);
            $this->seed_referrers($referrers, $date, $pageviews);
            $this->seed_utm_stats($utm_values, $date, $pageviews);
            echo "\r" . round($i / ($years * 365) * 100) . "% completed";
        }

        echo "\rDone. Generated {$years} years of stats.\n";
    }

    protected function seed_post_stats(array $paths, string $date, int $pageviews): void
    {
        global $wpdb;
        $values = array();
        $pageviews_per_post = $pageviews / count($paths) * 2;
        foreach ($paths as $path_id) {
            $post_pageviews = (int) ($pageviews_per_post * rand(5, 15) * 0.1);
            $post_visitors = (int) (rand(1, 3) * $post_pageviews * 0.1);
            array_push($values, $date, $path_id, 0, $post_pageviews, $post_visitors);
        }

        $placeholders = rtrim(str_repeat('(%s,%d,%d,%d,%d),', count($paths)), ',');
        $wpdb->query($wpdb->prepare("INSERT INTO {$wpdb->prefix}koko_analytics_post_stats(date, path_id, post_id, pageviews, visitors) VALUES {$placeholders}", $values));
    }

    protected function seed_referrers(array $referrers, string $date, int $pageviews): void 
    {
        global $wpdb;
        $values = array();
        $pageviews_per_referrer = $pageviews / count($referrers) * 2;
        foreach ($referrers as $referrer_id) {
            $referrer_pageviews = (int) ($pageviews_per_referrer * rand(5, 15) * 0.1);
            $referrer_visitors = (int) (rand(1, 3) * $referrer_pageviews * 0.1);
            array_push($values, $date, $referrer_id, $referrer_pageviews, $referrer_visitors);
        }
        $placeholders = rtrim(str_repeat('(%s,%d,%d,%d),', count($referrers)), ',');
        $wpdb->query($wpdb->prepare("INSERT INTO {$wpdb->prefix}koko_analytics_referrer_stats(date, id, hits, unique_hits) VALUES {$placeholders}", $values));
    }

    protected function seed_utm_stats(array $utm_values, string $date, int $pageviews): void
    {
        global $wpdb;

        foreach ($utm_values as $type => $ids) {
            if (empty($ids)) {
                continue;
            }

            $table = $wpdb->prefix . 'koko_analytics_' . $type . '_stats';
            if (!$this->table_exists($table)) {
                continue;
            }

            $values = array();
            $pageviews_per_value = $pageviews / count($ids) * 0.5;
            foreach ($ids as $id) {
                $utm_pageviews = (int) ($pageviews_per_value * rand(5, 15) * 0.1);
                $utm_visitors = (int) (rand(1, 3) * $utm_pageviews * 0.1);
                array_push($values, $date, $id, $utm_pageviews, $utm_visitors);
            }

            $placeholders = rtrim(str_repeat('(%s,%d,%d,%d),', count($ids)), ',');
            $wpdb->query($wpdb->prepare("INSERT INTO $table(date, id, hits, unique_hits) VALUES {$placeholders}", $values));
        }
    }
}

require dirname(__DIR__, 4) . '/wp-config.php';
(new Command())($argv);
